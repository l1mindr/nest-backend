{
  "name": "nest-backend",
  "version": "0.0.1",
  "description": "",
  "author": "Mohamadreza Irick",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=production nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config jest.unit.config.ts --runInBand",
    "test:unit": "jest --config jest.unit.config.ts --runInBand",
    "test:watch": "NODE_ENV=test jest --watch --config jest.config.ts --runInBand",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test LOG_LEVEL=error jest --config jest.e2e.config.ts --runInBand",
    "migration:create": "pnpm exec typeorm migration:create",
    "migration:generate": "pnpm run build && pnpm exec typeorm migration:generate -d dist/infrastructure/databases/postgres/data-source -p",
    "premigration:run": "pnpm run build",
    "migration:run": "pnpm exec typeorm migration:run -d dist/infrastructure/databases/postgres/data-source",
    "migration:revert": "pnpm exec typeorm migration:revert -d dist/infrastructure/databases/postgres/data-source",
    "migration:show": "pnpm exec typeorm migration:show",
    "docs": "pnpm exec compodoc -p tsconfig.json -s --port 3333 -w --theme material",
    "prepare": "husky",
    "deprecated": "pnpm exec ts-node findDeprecatedFiles.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "@types/bcrypt": "^6.0.0",
    "@types/ioredis": "^5.0.0",
    "bcrypt": "^6.0.0",
    "chalk": "4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@compodoc/compodoc": "^2.0.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "conventional-changelog-atom": "^5.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "packageManager": "pnpm@11.9.0"
}
